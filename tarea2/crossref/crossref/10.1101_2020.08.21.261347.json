    "abstract": "<jats:title>Summary</jats:title>\n                <jats:p>Covidex is an open-source, alignment-free machine learning subtyping tool for viral species. It is a shiny app that allows a fast and accurate classification in pre-defined clusters for SARS-CoV-2 and FMDV genome sequences. The user can also build its own classification models with the Covidex model generator.</jats:p>\n                <jats:sec>\n                  <jats:title>Availability</jats:title>\n                  <jats:p>\n                    Covidex is open-source, cross-platform compatible, and is available under the terms of the GNU General Public License v3 (\n                    <jats:ext-link xmlns:xlink=\"http://www.w3.org/1999/xlink\" ext-link-type=\"uri\" xlink:href=\"http://www.gnu.org/licenses/gpl.txt\">http://www.gnu.org/licenses/gpl.txt</jats:ext-link>\n                    ). Covidex is available via SourceForge\n                    <jats:ext-link xmlns:xlink=\"http://www.w3.org/1999/xlink\" ext-link-type=\"uri\" xlink:href=\"http://sourceforge.net/projects/covidex\">https://sourceforge.net/projects/covidex</jats:ext-link>\n                    or the web application\n                    <jats:ext-link xmlns:xlink=\"http://www.w3.org/1999/xlink\" ext-link-type=\"uri\" xlink:href=\"https://cacciabue.shinyapps.io/shiny2/\">https://cacciabue.shinyapps.io/shiny2/</jats:ext-link>\n                  </jats:p>\n                </jats:sec>\n                <jats:sec>\n                  <jats:title>Contact</jats:title>\n                  <jats:p>\n                    <jats:email>cacciabue.marco@inta.gob.ar</jats:email>\n                    ;\n                    <jats:email>marcocacciabue@yahoo.com</jats:email>\n                  </jats:p>\n                </jats:sec>",
