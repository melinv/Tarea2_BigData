      {
        "key": "2021020610050670000_2020.08.24.20180927v1.13",
        "unstructured": "The effective reproduction number Rt of an epidemic can be interpreted as the average number of new infections directly caused by a single infected patient. The effective reproduction number equals the basic reproduction number R0 in a fully susceptible population when no mitigation strategy is active."
      },
      {
        "key": "2021020610050670000_2020.08.24.20180927v1.14",
        "doi-asserted-by": "publisher",
        "DOI": "10.1111/j.0014-3820.2003.tb00368.x"
      },
      {
        "key": "2021020610050670000_2020.08.24.20180927v1.15",
        "first-page": "178",
        "volume": "1",
