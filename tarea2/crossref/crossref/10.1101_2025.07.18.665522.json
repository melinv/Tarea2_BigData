    "abstract": "<jats:title>Graphical abstract</jats:title>\n                <jats:p>To enable the analysis of B cell and T cell immune responses in mouse lymph nodes, spleen, and bone marrow, including different B cell and T cell subsets and their activation status, as well as the antigen-reactivity and isotype of B cells and level of T cell exhaustion, a novel 31-parameter spectral flow cytometry panel was developed.</jats:p>\n                <jats:sec>\n                  <jats:title>Abstract Figure</jats:title>\n                  <jats:fig id=\"ufig1\" position=\"float\" orientation=\"portrait\" fig-type=\"figure\">\n                    <jats:graphic xmlns:xlink=\"http://www.w3.org/1999/xlink\" xlink:href=\"665522v1_ufig1\" position=\"float\" orientation=\"portrait\"/>\n                  </jats:fig>\n                  <jats:p>\n                    Created in\n                    <jats:ext-link xmlns:xlink=\"http://www.w3.org/1999/xlink\" ext-link-type=\"uri\" xlink:href=\"https://biorender.com\">https://BioRender.com</jats:ext-link>\n                  </jats:p>\n                </jats:sec>",
